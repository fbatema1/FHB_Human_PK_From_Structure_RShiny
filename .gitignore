v2/data/processed/*.npy
v2/data/processed/*.npz
v2/data/processed/*.pt

# Office temp/lock files
~$*

# Models — serialized model weights (too large for GitHub)
*.pkl
*.pt
*.pth
*.joblib
models/saved/

